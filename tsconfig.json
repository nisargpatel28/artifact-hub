{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@artifact-hub/types": ["packages/types/src/index.ts"],
      "@artifact-hub/types/*": ["packages/types/src/*"]
    }
  },
  "exclude": ["**/node_modules", "**/dist", "**/.next"]
}
